# API key for the Groq chat-completions API used by lib/ai/groq.ts. Never
# exposed to the client — only imported by server-side modules (lib/ai/groq.ts,
# lib/langgraph/structured-output.ts) and API routes.
GROQ_API_KEY=

# Optional: override the default Groq model (llama-3.3-70b-versatile)
GROQ_MODEL=

# AES-256-GCM key (base64-encoded, must decode to exactly 32 bytes) used by
# lib/monitoring/credential-crypto.ts to encrypt AWS/GCP/Prometheus
# monitoring credentials before they're stored in Postgres (MonitoringConnection).
# Never exposed to the client. Generate with: openssl rand -base64 32
MONITORING_CREDENTIALS_ENCRYPTION_KEY=

# Optional. When set, lib/terraform/templates.ts redirects every AWS
# provider endpoint here instead of real AWS, so terraformApplyWorker's
# `terraform apply` (lib/terraform/sandbox.ts, allowNetwork: true) actually
# succeeds against a real local AWS API emulator (LocalStack — see
# docker-compose.yml's `localstack` service) instead of always failing real
# AWS authentication (this app never has real AWS credentials). Leave unset
# to keep today's behavior: apply genuinely reaches real AWS and fails,
# which verificationWorker/rollbackWorker correctly detect and revert.
#
# - `docker compose up`: already set for you (docker-compose.yml points
#   the app container at `http://localstack:4566`, the compose network's
#   service name — don't override this one).
# - `npm run dev` with LocalStack running via
#   `docker run -p 4566:4566 localstack/localstack`: use
#   http://localhost:4566
# - `npm run dev` where sandbox.ts's Docker-in-Docker path is active (Docker
#   reachable from the dev process itself — see sandbox.ts's isDockerAvailable)
#   and LocalStack runs standalone on the host: use
#   http://host.docker.internal:4566 (sandbox.ts adds the Linux
#   --add-host mapping this needs automatically).
TERRAFORM_AWS_ENDPOINT=

# PostgreSQL connection string for Prisma (lib/db/client.ts, prisma/schema.prisma).
# For `npm run dev` against a local Postgres, point this at localhost; when
# running via `docker compose up`, the app container uses the postgres
# service name instead (see docker-compose.yml — that file builds
# DATABASE_URL from POSTGRES_* below, so you don't need to duplicate this
# value for Docker).
#
# Using Neon instead of local Postgres: set DATABASE_URL to Neon's pooled
# connection string with `&pgbouncer=true` appended (Prisma needs that to
# skip server-side prepared statements PgBouncer's transaction-pooling mode
# can't support), and set DIRECT_DATABASE_URL to the same connection with the
# "-pooler" host segment removed — `prisma migrate` needs the direct
# connection for advisory locks the pooler doesn't support. NEON_DB_CONNECTION_STRING
# is kept as the original, unmodified value Neon issued, for reference.
DATABASE_URL="postgresql://cloudpilot:cloudpilot@localhost:5432/cloudpilot?schema=public"
DIRECT_DATABASE_URL=
NEON_DB_CONNECTION_STRING=

# --- docker-compose.yml only (ignored by `npm run dev`) ---

# Postgres container credentials + exposed host ports.
POSTGRES_USER=cloudpilot
POSTGRES_PASSWORD=cloudpilot
POSTGRES_DB=cloudpilot
POSTGRES_PORT=5432
APP_PORT=3000
