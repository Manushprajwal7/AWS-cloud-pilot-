# API key for the Groq chat-completions API used by lib/ai/groq.ts. Never
# exposed to the client — only imported by server-side modules (lib/ai/groq.ts,
# lib/langgraph/structured-output.ts) and API routes.
GROQ_API_KEY=

# Optional: override the default Groq model (llama-3.3-70b-versatile)
GROQ_MODEL=

# PostgreSQL connection string for Prisma (lib/db/client.ts, prisma/schema.prisma).
# For `npm run dev` against a local Postgres, point this at localhost; when
# running via `docker compose up`, the app/worker containers use the
# postgres/redis service names instead (see docker-compose.yml — that file
# builds DATABASE_URL/REDIS_URL from POSTGRES_* below, so you don't need to
# duplicate this value for Docker).
DATABASE_URL="postgresql://cloudpilot:cloudpilot@localhost:5432/cloudpilot?schema=public"

# Redis connection string for BullMQ (lib/queue/connection.ts). Defaults to
# redis://localhost:6379 if unset.
REDIS_URL=redis://localhost:6379

# --- docker-compose.yml only (ignored by `npm run dev` / `npm run worker`) ---

# Postgres container credentials + exposed host ports.
POSTGRES_USER=cloudpilot
POSTGRES_PASSWORD=cloudpilot
POSTGRES_DB=cloudpilot
POSTGRES_PORT=5432
REDIS_PORT=6379
APP_PORT=3000

# Optional: per-worker BullMQ concurrency (see workers/*.ts for defaults).
TERRAFORM_WORKER_CONCURRENCY=2
SIMULATION_WORKER_CONCURRENCY=4
VERIFICATION_WORKER_CONCURRENCY=4
AUDIT_WORKER_CONCURRENCY=8
